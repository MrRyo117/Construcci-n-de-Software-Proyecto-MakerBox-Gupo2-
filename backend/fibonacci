public class fibonacci {

    public static void main (String[] args){
        int numeroTerminos= 6;

        System.out.println("------Calculando Fibonaccci--------")
        for (int i=0; i<numeroTerminos, i++){
            System.out.println("fibonacci de " + i + "es: " fibonacciErroeno(i)) 
        }
    }

    public static int fibonacciErroeno(int n){
    if(n<=1){
        return 1;
    }
    return n +fibonacciErroeno(n-1);
}
}
