const users = [
    {email: "", password: ""}
];

app.post('login', (req, res)=>{
        {
    const {email,password}=req.body;

    const user = users.find(u=> u.email === email && u.password === password);

    if(user){
        res.status(200).send("Sesión Iniciada")
    }else{
        res.status(401).send("Información Incorrecta")
    }
    }
});



