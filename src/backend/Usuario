class Usuario{
    constructor(id ,nombre , apellido ,correo, rol, contrasena , estado ){
        this.id = id;
        this.nombre = nombre;
        this.apellido = apellido;
        this.correo = correo;
        this.rol = rol;
        this.contrasena = contrasena;
        this.estado = estado;
    }
}

GPUShaderModule.exports = Usuario;